# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.
.claude

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local SQLite database
*.sqlite
*.sqlite-journal
*.sqlite-wal
*.sqlite-shm

# local data dir (sqlite + cached artwork when DATABASE_PATH/IMAGE_DIR point here)
/data

# local media files (sample + user library) — keep the folder + README, ignore the videos
/public/sample/*.mp4
/media/*
!/media/README.md

# user-uploaded profile avatars — keep the folder, ignore the images
/public/avatars/*
!/public/avatars/.gitkeep
